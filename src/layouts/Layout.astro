---
import ToolFooter from "../components/ToolFooter.astro";
import '../styles/global.css';
const { title = 'lilSVG', description = '' } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-white dark:bg-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <script is:inline>
      // Set the theme before first paint to avoid a flash.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white dark:bg-dark text-dark dark:text-white">
    <header class="border-b border-gray-200 dark:border-dark-3">
      <div class="container flex items-center justify-between py-4">
