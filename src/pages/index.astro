---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="lilSVG - Free SVG Viewer, Editor & Converter | lilAgents"
  description="Paste SVG code to preview it live, recolor it, set a transparent background, and download it as SVG, PNG, JPG, or WebP. A free tool by lilAgents."
>
  <section class="pt-12 pb-16 lg:pt-16 bg-white dark:bg-dark">
    <div class="container">
      <div id="svg-tool" class="mx-auto max-w-6xl">

        <header class="text-center mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-dark dark:text-white mb-2">
            <span class="text-primary">lil</span>SVG
          </h1>
          <p class="text-body-color dark:text-dark-6">Paste SVG code to preview, recolor, and export as SVG, PNG, JPG, or WebP</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">

          <!-- Left: code -->
          <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-4">
            <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
              <span class="text-sm font-semibold text-dark dark:text-white">SVG code</span>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="btn-prettify" class="chip">Prettify</button>
                <button type="button" id="btn-minify" class="chip">Minify</button>
                <button type="button" id="btn-sample" class="chip">Sample</button>
                <button type="button" id="btn-clear" class="chip">Clear</button>
              </div>
            </div>
            <textarea id="svg-input" spellcheck="false" autocomplete="off" autocapitalize="off"
              placeholder="Paste your <svg> ... </svg> here"
              class="w-full h-[300px] lg:h-[520px] font-mono text-[13px] leading-relaxed px-3 py-2 border border-gray-300 rounded-lg resize-y focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-dark dark:text-white"></textarea>
            <p id="svg-error" class="mt-2 text-sm text-red-500 hidden"></p>
          </div>

          <!-- Right: preview + controls -->
          <div class="lg:sticky lg:top-6 space-y-4">

            <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-4">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-dark dark:text-white">Preview</span>
                <span id="svg-dims" class="text-xs text-body-color dark:text-dark-6"></span>
              </div>
              <div id="preview-wrap" class="checkerboard rounded-lg h-[260px] flex items-center justify-center overflow-hidden p-4">
                <div id="svg-preview" class="max-w-full max-h-full flex items-center justify-center text-body-color dark:text-dark-6">
                  <span class="text-sm">Preview appears here</span>
                </div>
              </div>
              <div class="mt-4">
                <label class="block text-sm font-medium text-gray-700 mb-1.5">Background</label>
                <div class="flex items-center gap-2 flex-wrap" id="bg-options">
                  <button type="button" data-bg="transparent" class="bg-chip active">Transparent</button>
                  <button type="button" data-bg="#ffffff" class="bg-chip">White</button>
                  <button type="button" data-bg="#000000" class="bg-chip">Black</button>
                  <label class="inline-flex items-center gap-1.5 text-xs text-gray-700 cursor-pointer">
                    Custom
                    <input type="color" id="bg-custom" value="#536ee5" class="color-input">
                  </label>
                </div>
              </div>
            </div>

            <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-4">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-dark dark:text-white">Colors</span>
                <button type="button" id="btn-reset-colors" class="chip hidden">Reset colors</button>
              </div>
              <div id="color-swatches" class="flex flex-wrap gap-2">
                <span class="text-xs text-body-color dark:text-dark-6">Paste an SVG to detect its colors.</span>
              </div>
              <div class="mt-3 flex items-center gap-2 flex-wrap">
                <span class="text-xs text-gray-700">Recolor everything:</span>
                <input type="color" id="mono-color" value="#536ee5" class="color-input">
                <button type="button" id="btn-mono-apply" class="chip">Apply to all</button>
              </div>
            </div>

            <div class="bg-white dark:bg-dark-2 rounded-2xl border border-gray-200 dark:border-dark-3 shadow-sm p-4">
              <div class="grid grid-cols-2 gap-3 mb-3">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Format</label>
                  <select id="export-format" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="png" selected>PNG</option>
                    <option value="svg">SVG</option>
                    <option value="jpeg">JPG</option>
                    <option value="webp">WebP</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Size</label>
                  <select id="export-scale" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="1">1x</option>
                    <option value="2" selected>2x</option>
                    <option value="4">4x</option>
                    <option value="custom">Custom width</option>
                  </select>
                </div>
              </div>
              <input type="number" id="export-width" min="1" max="8000" placeholder="Width in pixels"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500 mb-3 hidden">
              <button type="button" id="btn-download" class="w-full px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-blue-dark transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Download
              </button>
              <div class="grid grid-cols-2 gap-2 mt-2">
                <button type="button" id="btn-copy-svg" class="chip">Copy SVG</button>
                <button type="button" id="btn-copy-datauri" class="chip">Copy data URI</button>
              </div>
              <button type="button" id="btn-copy-css" class="chip w-full mt-2">Copy as CSS background</button>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <style is:global>
    #svg-tool .chip { font-size: 13px; padding: 6px 12px; border-radius: 8px; background-color: #f3f4f6; color: #374151; font-weight: 500; transition: background-color .15s; }
    #svg-tool .chip:hover { background-color: #e5e7eb; }
    #svg-tool .bg-chip { font-size: 12px; padding: 5px 11px; border-radius: 8px; background-color: #f3f4f6; color: #6b7280; font-weight: 500; border: 2px solid transparent; }
    #svg-tool .bg-chip.active { border-color: var(--color-primary); color: var(--color-primary); }
    #svg-tool .color-input { width: 44px; height: 32px; border: 2px solid #e5e7eb; border-radius: 6px; cursor: pointer; background: transparent; padding: 0; }
    #svg-tool .swatch { display: inline-flex; align-items: center; gap: 6px; padding: 4px 6px 4px 4px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 12px; color: #374151; }
    #svg-tool .swatch input[type="color"] { width: 26px; height: 26px; border: 1px solid #d1d5db; border-radius: 5px; padding: 0; cursor: pointer; background: transparent; }
    #svg-tool .checkerboard {
      background-color: #fff;
      background-image:
        linear-gradient(45deg, #e2e5ea 25%, transparent 25%),
        linear-gradient(-45deg, #e2e5ea 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #e2e5ea 75%),
        linear-gradient(-45deg, transparent 75%, #e2e5ea 75%);
      background-size: 20px 20px;
      background-position: 0 0, 0 10px, 10px -10px, -10px 0;
    }
    #svg-tool #svg-preview svg { max-width: 100%; max-height: 220px; height: auto; display: block; }
    .dark #svg-tool .chip { background-color: var(--color-dark); color: #d1d5db; }
    .dark #svg-tool .chip:hover { background-color: #373737; }
    .dark #svg-tool .bg-chip { background-color: var(--color-dark); color: #9ca3af; }
    .dark #svg-tool .swatch { border-color: #374151; color: #d1d5db; }
    .dark #svg-tool .checkerboard { background-color: #16181d; background-image:
      linear-gradient(45deg, #24272e 25%, transparent 25%),
      linear-gradient(-45deg, #24272e 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #24272e 75%),
      linear-gradient(-45deg, transparent 75%, #24272e 75%); }
    .dark #svg-tool input, .dark #svg-tool select, .dark #svg-tool textarea { background-color: var(--color-dark); border-color: #374151; color: #fff; }
    .dark #svg-tool .border-gray-300 { border-color: #374151; }
    .dark #svg-tool .color-input { border-color: #374151; }
    .dark #svg-tool .text-gray-700 { color: #d1d5db; }
    #svg-tool .focus\:ring-blue-500:focus { --tw-ring-color: var(--color-primary); }
    #svg-tool .focus\:border-blue-500:focus { border-color: var(--color-primary); }
  </style>

  <script src="/tools/svg/app.js" is:inline></script>
</Layout>
